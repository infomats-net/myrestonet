
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "super_admin";
    }

    function isPartner() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "marketing_partner";
    }

    function belongsToRestaurant(restaurantId) {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUser().restaurantId == restaurantId;
    }

    function hasPermission(restaurantId, action) {
      if (isSuperAdmin()) return true;
      if (request.auth == null) return false;
      if (!exists(/databases/$(database)/documents/users/$(request.auth.uid))) return false;
      
      let userData = getUser();
      if (userData.restaurantId == restaurantId) return true;
      
      let restaurantData = get(/databases/$(database)/documents/restaurants/$(restaurantId)).data;
      if (isPartner() && restaurantData.partnerId == userData.partnerId) return true;
      
      return false;
    }

    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }

    match /countries { allow read: if true; }
    match /states { allow read: if true; }
    match /cities { 
      allow read: if true; 
      allow create: if request.auth != null;
    }

    match /tiers {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /partners/{partnerId} {
      allow read: if isSuperAdmin() || (isPartner() && request.auth.uid == partnerId);
      allow write: if isSuperAdmin(); 
    }

    match /restaurants/{restaurantId} {
      allow get: if true;
      allow read: if hasPermission(restaurantId, "read");
      allow update: if hasPermission(restaurantId, "update_settings");
      allow create: if isPartner() || isSuperAdmin();

      match /menus/{menuId} {
        allow read: if true;
        match /items/{itemId} {
          allow read: if true;
        }
      }

      match /reservations/{reservationId} {
        allow read: if hasPermission(restaurantId, "read");
        allow write: if hasPermission(restaurantId, "update_settings");
        allow create: if true; 
      }

      match /orders/{orderId} {
        allow read: if hasPermission(restaurantId, "read");
        allow update: if hasPermission(restaurantId, "update_settings");
        allow create: if true;
      }

      match /gallery/{imageId} {
        allow read: if true;
        allow write: if hasPermission(restaurantId, "update_settings");
      }

      match /design/{docId} {
        allow read: if true;
        allow write: if hasPermission(restaurantId, "update_settings");
      }

      match /config/{docId} {
        allow read: if true;
        allow write: if hasPermission(restaurantId, "update_settings");
      }
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin() || isPartner());
      allow list: if isPartner() || isSuperAdmin(); 
      allow create: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow update: if request.auth != null && (
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) || 
        isSuperAdmin()
      );
    }

    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read: if isSuperAdmin();
    }
  }
}
