
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && 
        getUser().role == "super_admin";
    }

    function belongsToRestaurant(restaurantId) {
      return request.auth != null && 
        getUser().restaurantId == restaurantId;
    }

    match /restaurants/{restaurantId} {
      // Public read for storefront
      allow get: if true;
      allow read, write: if isSuperAdmin() || belongsToRestaurant(restaurantId);

      match /{subcollection=**} {
        // Public read for menu items and public config
        allow get: if true;
        allow list: if true;
        allow read, write: if isSuperAdmin() || belongsToRestaurant(restaurantId);
      }
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isSuperAdmin();
      // Creation is now restricted to Super Admins only after initialization
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin();
    }
  }
}
