rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Platform level check avoiding recursion
    function isPlatformAdmin() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && userData.role == 'super_admin';
    }

    function isRestaurantAdmin(restaurantId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && 
             (userData.role == 'restaurant_admin' || userData.role == 'staff') && 
             userData.restaurantId == restaurantId;
    }

    // --- COLLECTION RULES ---

    match /customerProfiles/{customerId} {
      allow get: if isOwner(customerId) || isSignedIn(); 
      allow list: if isPlatformAdmin();
      allow create: if isSignedIn() && request.resource.data.firebaseAuthUid == request.auth.uid;
      allow update: if isOwner(customerId);
      allow delete: if isPlatformAdmin();

      match /addresses/{addressId} {
        allow read, write: if isOwner(customerId) || isPlatformAdmin();
      }
    }

    match /restaurants/{restaurantId} {
      // Public discovery
      allow get, list: if true;
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || isRestaurantAdmin(restaurantId);
      allow delete: if isPlatformAdmin();

      // Shared settings sub-collections
      match /menus/{menuId} { allow read: if true; allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin(); }
      match /gallery/{imageId} { allow read: if true; allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin(); }
      match /design/{docId} { allow read: if true; allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin(); }
      match /config/{docId} { allow read: if true; allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin(); }
      match /features/{docId} { allow read: if true; allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin(); }

      match /orders/{orderId} {
        allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isRestaurantAdmin(restaurantId) || isPlatformAdmin());
        allow create: if isSignedIn();
        allow update: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
        allow delete: if isPlatformAdmin();
      }

      match /reservations/{reservationId} {
        allow get, list: if isRestaurantAdmin(restaurantId) || isPlatformAdmin() || (isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid));
        allow create: if isSignedIn();
        allow update: if isRestaurantAdmin(restaurantId) || isPlatformAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
        allow delete: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
      }
    }

    match /users/{userId} {
      // Simplified rules to avoid recursion during login
      allow get: if isSignedIn() && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
      allow list: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }
    
    match /cities/{cityId} { allow read: if true; allow create: if isSignedIn(); }
    match /tiers/{tierId} { allow read: if true; allow write: if isPlatformAdmin(); }
    match /partners/{partnerId} { allow read: if isSignedIn(); allow write: if isPlatformAdmin(); }
    match /mail/{mailId} { allow create: if isSignedIn(); }
  }
}
