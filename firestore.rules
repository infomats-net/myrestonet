
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid)) ||
        request.auth.token.email == "infomats.net@gmail.com"
      );
    }

    function getRestaurantAdminId(restaurantId) {
      return get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.adminUserId;
    }

    function isRestaurantOwner(restaurantId) {
      return isSignedIn() && (isSuperAdmin() || request.auth.uid == getRestaurantAdminId(restaurantId));
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSuperAdmin();
      allow update, delete: if isRestaurantOwner(restaurantId);

      match /design/{document=**} {
        allow get: if true;
        allow write: if isRestaurantOwner(restaurantId);
      }

      match /menus/{menuId} {
        allow get, list: if true;
        allow write: if isRestaurantOwner(restaurantId);

        match /menuItems/{menuItemId} {
          allow get, list: if true;
          allow write: if isRestaurantOwner(restaurantId);
        }
      }

      match /orders/{orderId} {
        allow read: if isRestaurantOwner(restaurantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
        allow create: if isSignedIn();
        allow update: if isRestaurantOwner(restaurantId) || (isSignedIn() && resource.data.userId == request.auth.uid);
      }
    }
  }
}
