
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid)) ||
        request.auth.token.email == "infomats.net@gmail.com"
      );
    }

    function isRestaurantAdmin(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    function isDataAdmin(data) {
      return isSignedIn() && (request.auth.uid == data.adminUserId || isSuperAdmin());
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin() || (resource != null && isDataAdmin(resource.data));

      match /design/{designId} {
        allow get: if true;
        allow write: if isSuperAdmin() || isRestaurantAdmin(get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.adminUserId);
      }

      match /menus/{menuId} {
        allow get, list: if true;
        allow create, update, delete: if isSuperAdmin() || isRestaurantAdmin(request.resource.data.adminUserId);

        match /menuItems/{menuItemId} {
          allow get, list: if true;
          allow create, update, delete: if isSuperAdmin() || isRestaurantAdmin(request.resource.data.adminUserId);
        }
      }

      match /orders/{orderId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
      }
    }
  }
}
