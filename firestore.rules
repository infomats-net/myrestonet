rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a multi-tenant restaurant management and ordering system. 
     * Security is enforced through a combination of global roles (Super Admin), 
     * shared administrative access (Restaurant Admins), and individual ownership (Customers).
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getAuthProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && (getAuthProfile().role == 'super_admin' || getAuthProfile().role == 'superadmin');
    }

    function hasAdminAccess(adminIds) {
      return isSignedIn() && (request.auth.uid in adminIds || isSuperAdmin());
    }

    function isRestaurantAdminLookup(restaurantId) {
      return isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.adminUserIds || isSuperAdmin());
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isSuperAdmin()) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isSuperAdmin() && resource != null;
    }

    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSuperAdmin();
      allow update: if (hasAdminAccess(resource.data.adminUserIds) || isSuperAdmin()) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isSuperAdmin() && resource != null;
    }

    // Design settings subcollection
    match /restaurants/{restaurantId}/design/settings {
      allow get: if true;
      allow write: if isRestaurantAdminLookup(restaurantId);
    }

    // Config subcollection (Operating hours, Payments, etc)
    match /restaurants/{restaurantId}/config/{configId} {
      allow get: if true;
      allow write: if isRestaurantAdminLookup(restaurantId);
    }

    match /restaurants/{restaurantId}/menus/{menuId} {
      allow get, list: if true;
      allow create: if isRestaurantAdminLookup(restaurantId);
      allow update: if isRestaurantAdminLookup(restaurantId);
      allow delete: if isRestaurantAdminLookup(restaurantId);
    }

    match /restaurants/{restaurantId}/menus/{menuId}/menuItems/{menuItemId} {
      allow get, list: if true;
      allow create: if isRestaurantAdminLookup(restaurantId);
      allow update: if isRestaurantAdminLookup(restaurantId);
      allow delete: if isRestaurantAdminLookup(restaurantId);
    }

    match /restaurants/{restaurantId}/orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (isOwner(resource.data.customerId) || isRestaurantAdminLookup(restaurantId));
      allow list: if isSignedIn() && isRestaurantAdminLookup(restaurantId);
      allow update: if isRestaurantAdminLookup(restaurantId);
    }

    match /superAdmins/{userId} {
      allow read, write: if isSuperAdmin();
    }

  }
}