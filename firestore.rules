
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && 
        getUser().role == "super_admin";
    }

    function belongsToRestaurant(restaurantId) {
      return request.auth != null && 
        getUser().restaurantId == restaurantId;
    }

    match /restaurants/{restaurantId} {
      // Public read for storefront info (name, etc)
      allow get: if true;
      
      // Admin read/write for own restaurant or Super Admin
      allow read, write: if isSuperAdmin() || belongsToRestaurant(restaurantId);

      match /{subcollection=**} {
        // Menu is public read for storefront
        allow read: if subcollection == 'menu' || isSuperAdmin() || belongsToRestaurant(restaurantId);
        // Everything else is protected
        allow read, write: if isSuperAdmin() || belongsToRestaurant(restaurantId);
      }
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isSuperAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
