
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPlatformAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid));
    }

    function isRestaurantAdmin(restaurantId) {
      return isSignedIn() && exists(/databases/$(database)/documents/restaurants/$(restaurantId)/adminUsers/$(request.auth.uid));
    }

    function isExistingOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    match /customerProfiles/{customerId} {
      allow get, list: if isOwner(customerId) || isPlatformAdmin();
      allow create: if isSignedIn() && request.resource.data.firebaseAuthUid == request.auth.uid;
      allow update: if isOwner(customerId);
      allow delete: if isPlatformAdmin();

      match /addresses/{addressId} {
        allow read, write: if isOwner(customerId) || isPlatformAdmin();
      }
    }

    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || isRestaurantAdmin(restaurantId);
      allow delete: if isPlatformAdmin();

      match /menuItems/{menuItemId} {
        allow get, list: if true;
        allow create, update, delete: if isPlatformAdmin() || isRestaurantAdmin(restaurantId);
      }

      match /adminUsers/{userId} {
        allow read: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
        allow create, update, delete: if isPlatformAdmin();
      }

      match /reservations/{reservationId} {
        allow get, list: if isRestaurantAdmin(restaurantId) || isPlatformAdmin() || (isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid));
        allow create: if isSignedIn();
        allow update: if isRestaurantAdmin(restaurantId) || isPlatformAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
        allow delete: if isPlatformAdmin();
      }
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isRestaurantAdmin(resource.data.restaurantId) || isPlatformAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.customerId == request.auth.uid || isRestaurantAdmin(resource.data.restaurantId) || isPlatformAdmin());
      allow delete: if isPlatformAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isExistingOwner('customerId') || isPlatformAdmin();
    }

    match /platformAdmins/{userId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isPlatformAdmin() || isRestaurantAdmin(resource.data.restaurantId);
      allow write: if isOwner(userId) || isPlatformAdmin();
    }
    
    match /cities/{cityId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
    
    match /tiers/{tierId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }
    
    match /partners/{partnerId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }
    
    match /mail/{mailId} {
      allow create: if isSignedIn();
    }
  }
}
