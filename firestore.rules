rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a multi-tenant restaurant management and ordering system. 
     * Security is enforced through a combination of global roles (Super Admin), 
     * shared administrative access (Restaurant Admins), and individual ownership (Customers).
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Faster check using marker collection
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    // Comprehensive check for restaurant admin rights
    function isRestaurantAdmin(restaurantId) {
      if (!isSignedIn()) return false;
      if (isSuperAdmin()) return true;
      
      // Method 1: Check user profile document
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userProfile = exists(userPath) ? get(userPath).data : null;
      
      if (userProfile != null) {
        let role = userProfile.get('role', 'none').lower();
        let isRoleMatch = role == 'restaurant_admin' || role == 'restaurantadmin';
        if (isRoleMatch && userProfile.get('restaurantId', '') == restaurantId) return true;
      }

      // Method 2: Fallback check on the restaurant document itself
      let restPath = /databases/$(database)/documents/restaurants/$(restaurantId);
      let restaurant = exists(restPath) ? get(restPath).data : null;
      
      return restaurant != null && request.auth.uid in restaurant.get('adminUserIds', []);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create, delete: if isSuperAdmin();
      allow update: if isRestaurantAdmin(restaurantId);

      // Design and Config are public for storefront, admin-only for writes
      match /design/{docId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId);
      }
      match /config/{docId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId);
      }

      // Menus and items are public for browsing
      match /menus/{menuId} {
        allow get, list: if true;
        allow create, update, delete: if isRestaurantAdmin(restaurantId);

        match /menuItems/{itemId} {
          allow get, list: if true;
          allow create, update, delete: if isRestaurantAdmin(restaurantId);
        }
      }

      // Orders: High security required
      match /orders/{orderId} {
        // Anyone signed in (including anonymous) can place an order
        allow create: if isSignedIn();
        // Only the customer who placed it OR the restaurant admin can view it
        allow get: if isSignedIn() && (isOwner(resource.data.customerId) || isRestaurantAdmin(restaurantId));
        // Only the restaurant admin can list all orders for processing
        allow list: if isRestaurantAdmin(restaurantId);
        // Only the restaurant admin can update status (Accepted, Preparing, etc)
        allow update: if isRestaurantAdmin(restaurantId);
        // Orders are generally preserved for auditing
        allow delete: if false;
      }
    }

    match /superAdmins/{userId} {
      allow read, write: if isSuperAdmin();
    }

  }
}