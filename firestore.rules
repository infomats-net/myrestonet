
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && getUser().role == "super_admin";
    }

    function isPartner() {
      return request.auth != null && getUser().role == "marketing_partner";
    }

    function belongsToRestaurant(restaurantId) {
      return request.auth != null && getUser().restaurantId == restaurantId;
    }

    function belongsToPartner(partnerId) {
      return isPartner() && getUser().partnerId == partnerId;
    }

    match /partners/{partnerId} {
      allow read: if isSuperAdmin() || belongsToPartner(partnerId);
      allow write: if isSuperAdmin();
      
      match /earnings/{monthId} {
        allow read: if isSuperAdmin() || belongsToPartner(partnerId);
        allow write: if isSuperAdmin();
      }
    }

    match /restaurants/{restaurantId} {
      // Public read for storefront
      allow get: if true;
      allow read: if isSuperAdmin() 
          || belongsToRestaurant(restaurantId) 
          || (resource.data.partnerId != null && belongsToPartner(resource.data.partnerId));
      
      allow write: if isSuperAdmin()
          || (request.auth != null && getUser().role == "marketing_partner" && request.resource.data.partnerId == getUser().partnerId);

      match /{subcollection=**} {
        allow get: if true;
        allow list: if true;
        allow read, write: if isSuperAdmin() 
            || belongsToRestaurant(restaurantId)
            || (get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.partnerId != null && belongsToPartner(get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.partnerId));
      }
    }

    match /users/{userId} {
      // Allow users to check for email uniqueness (read-only for specific fields)
      allow list: if request.auth != null;
      allow read: if request.auth.uid == userId || isSuperAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
