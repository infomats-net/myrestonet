rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a multi-tenant restaurant management and ordering system. 
     * Security is enforced through a combination of global roles (Super Admin), 
     * shared administrative access (Restaurant Admins), and individual ownership (Customers).
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Faster check using marker collection
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function getAuthProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isRestaurantAdminLookup(restaurantId) {
      if (!isSignedIn()) return false;
      if (isSuperAdmin()) return true;
      
      // Check user profile for role and matching restaurantId
      let profile = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let isRestAdmin = profile.role in ['restaurant_admin', 'restaurantadmin'];
      if (isRestAdmin && profile.restaurantId == restaurantId) return true;

      // Fallback check on the restaurant document itself
      return request.auth.uid in get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.adminUserIds;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isSuperAdmin()) && resource != null;
      allow delete: if isSuperAdmin();
    }

    match /restaurants/{restaurantId} {
      allow get, list: if true;
      allow create: if isSuperAdmin();
      allow update: if isRestaurantAdminLookup(restaurantId);
      allow delete: if isSuperAdmin();
    }

    match /restaurants/{restaurantId}/design/settings {
      allow get: if true;
      allow write: if isRestaurantAdminLookup(restaurantId);
    }

    match /restaurants/{restaurantId}/config/{configId} {
      allow get: if true;
      allow write: if isRestaurantAdminLookup(restaurantId);
    }

    match /restaurants/{restaurantId}/menus/{menuId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantAdminLookup(restaurantId);
    }

    match /restaurants/{restaurantId}/menus/{menuId}/menuItems/{menuItemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantAdminLookup(restaurantId);
    }

    match /restaurants/{restaurantId}/orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (isOwner(resource.data.customerId) || isRestaurantAdminLookup(restaurantId));
      allow list: if isSignedIn() && isRestaurantAdminLookup(restaurantId);
      allow update: if isRestaurantAdminLookup(restaurantId);
    }

    match /superAdmins/{userId} {
      allow read, write: if isSuperAdmin();
    }

  }
}