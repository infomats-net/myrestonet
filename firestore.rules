rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && getUser().role == "super_admin";
    }

    function isPartner() {
      return request.auth != null && getUser().role == "marketing_partner";
    }

    function isSupport() {
      return request.auth != null && (getUser().role == "support" || getUser().role == "helper");
    }

    function belongsToRestaurant(restaurantId) {
      return request.auth != null && getUser().restaurantId == restaurantId;
    }

    function belongsToPartner(partnerId) {
      return isPartner() && getUser().partnerId == partnerId;
    }

    function hasPermission(restaurantId, action) {
      if (isSuperAdmin()) return true;
      if (request.auth == null) return false;
      let userData = getUser();
      if (userData.restaurantId == restaurantId) return true;
      
      let restaurantData = get(/databases/$(database)/documents/restaurants/$(restaurantId)).data;
      if (isPartner() && restaurantData.partnerId == userData.partnerId) return true;
      
      if (isSupport()) {
        let assigned = userData.assignedRestaurants;
        return assigned.exists(r, 
          r.restaurantId == restaurantId && 
          r.permissions.hasAny([action]) && 
          (r.expiryDate == null || timestamp(r.expiryDate) > request.time)
        );
      }
      return false;
    }

    match /partners/{partnerId} {
      allow read: if isSuperAdmin() || belongsToPartner(partnerId);
      allow write: if isSuperAdmin();
    }

    match /restaurants/{restaurantId} {
      allow get: if true;
      allow read: if hasPermission(restaurantId, "read");
      allow update: if hasPermission(restaurantId, "update_settings");
      allow create: if isSuperAdmin() || isPartner();

      match /menus/{menuId} {
        allow read: if true;
        match /items/{itemId} {
          allow read: if true;
        }
      }

      match /reservations/{reservationId} {
        allow read: if hasPermission(restaurantId, "read");
        allow write: if hasPermission(restaurantId, "update_settings") || isSuperAdmin();
        allow create: if true; 
      }

      match /orders/{orderId} {
        allow read: if hasPermission(restaurantId, "read");
        allow update: if hasPermission(restaurantId, "update_settings");
        allow create: if true;
      }

      match /gallery/{imageId} {
        allow read: if true;
        allow write: if hasPermission(restaurantId, "update_settings");
      }

      match /design/{docId} {
        allow read: if true;
        allow write: if hasPermission(restaurantId, "update_settings");
      }

      match /config/{docId} {
        allow read: if true;
        allow write: if hasPermission(restaurantId, "update_settings");
      }
    }

    match /users/{userId} {
      allow list: if isSuperAdmin();
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow update: if isSuperAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow create: if isSuperAdmin() || isPartner();
      allow delete: if isSuperAdmin();
    }
  }
}