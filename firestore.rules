
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && 
        getUser().role == "super_admin";
    }

    function belongsToRestaurant(restaurantId) {
      return request.auth != null && 
        getUser().restaurantId == restaurantId;
    }

    match /restaurants/{restaurantId} {
      // Public read for storefront (menu display, checkouts)
      allow get: if true;
      allow read, write: if isSuperAdmin() || belongsToRestaurant(restaurantId);

      match /menus/{menuId} {
        allow read: if true;
        allow write: if isSuperAdmin() || belongsToRestaurant(restaurantId);

        match /items/{itemId} {
          allow read: if true;
          allow write: if isSuperAdmin() || belongsToRestaurant(restaurantId);
        }
      }

      match /orders/{orderId} {
        // Customers can create orders (anonymous auth)
        allow create: if request.auth != null;
        // Admins can manage all orders in their tenant
        allow read, write: if isSuperAdmin() || belongsToRestaurant(restaurantId);
        // Users can read their own orders
        allow read: if request.auth.uid == resource.data.customerId;
      }

      match /{subcollection=**} {
        allow read, write: if isSuperAdmin() || belongsToRestaurant(restaurantId);
      }
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId || isSuperAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
