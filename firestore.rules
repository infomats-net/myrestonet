
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check role from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == "super_admin" || 
        getUserData().role == "super_admin"
      );
    }

    function getUserRestaurant() {
      return getUserData().get('restaurantId', null);
    }

    // Tenant Isolation Logic
    match /restaurants/{restaurantId} {
      
      // Public read for storefront info
      allow get: if true; 
      
      // Admin read/write
      allow read, write: if isSuperAdmin() || 
        (isAuthenticated() && getUserRestaurant() == restaurantId);

      match /{subcollection=**} {
        // Menu and Design are public read
        allow read: if subcollection in ['menu', 'design', 'config'] || isSuperAdmin() || (isAuthenticated() && getUserRestaurant() == restaurantId);
        // Everything else is private
        allow write: if isSuperAdmin() || (isAuthenticated() && getUserRestaurant() == restaurantId);
      }
    }

    match /users/{userId} {
      // Users can always read and write their own profile
      allow read, write: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == userId);
    }
  }
}
