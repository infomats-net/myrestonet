
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      // Note: Custom claims check if available, or check users collection
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "super_admin");
    }

    function getUserRestaurant() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('restaurantId', null);
    }

    // Tenant Isolation Logic
    match /restaurants/{restaurantId} {
      
      // Public read for basic info (Storefront)
      allow get: if true; 
      // Admin read/write
      allow read, write: if isSuperAdmin() || 
        (isAuthenticated() && getUserRestaurant() == restaurantId);

      match /{subcollection=**} {
        // Orders and Payments are private to admin/customer
        // Menu items and Design are public read for storefront
        allow read: if subcollection in ['menu', 'design', 'config'] || isSuperAdmin() || (isAuthenticated() && getUserRestaurant() == restaurantId);
        allow write: if isSuperAdmin() || (isAuthenticated() && getUserRestaurant() == restaurantId);
      }
    }

    match /users/{userId} {
      allow read, write: if isSuperAdmin() || 
        request.auth.uid == userId;
    }
  }
}
