
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DINEFLOW GLOBAL SECURITY RULES
     * 
     * Hierarchical Access:
     * 1. Super Admins: Global read/write across all tenants.
     * 2. Restaurant Admins: Full control over their specific restaurant instance.
     * 3. Customers: Public browsing of menus/design.
     */

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Optimized Super Admin check using marker collection
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    // Direct check for Restaurant Admin rights
    // Verifies if the current user UID is present in the restaurant's adminUserIds array.
    function isRestaurantAdmin(restaurantId) {
      if (!isSignedIn()) return false;
      if (isSuperAdmin()) return true;
      
      // The restaurant document is the source of truth for its authorized admins.
      let restPath = /databases/$(database)/documents/restaurants/$(restaurantId);
      return exists(restPath) && (request.auth.uid in get(restPath).data.get('adminUserIds', []));
    }

    // --- Collection Rules ---

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.resource.data.id == userId;
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Restaurant Root and Subcollections
    match /restaurants/{restaurantId} {
      // Browsing basic info is public
      allow get, list: if true;
      
      // Management requires Super Admin or specific Restaurant Admin rights
      allow create, delete: if isSuperAdmin();
      allow update: if isRestaurantAdmin(restaurantId);

      // Design & Config: Public read for storefront, Admin write for dash
      match /design/{docId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId);
      }
      match /config/{docId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId);
      }

      // Menus & Items: Public read for browsing, Admin write for management
      match /menus/{menuId} {
        allow get, list: if true;
        allow create, update, delete: if isRestaurantAdmin(restaurantId);

        match /menuItems/{itemId} {
          allow get, list: if true;
          allow create, update, delete: if isRestaurantAdmin(restaurantId);
        }
      }
    }

    // Super Admin Privileged Access List
    match /superAdmins/{userId} {
      allow read, write: if isSuperAdmin();
    }

  }
}
