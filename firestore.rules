rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isPlatformAdmin() {
      return hasRole('super_admin');
    }

    function isRestaurantAdmin(restaurantId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (getUserData().role == 'restaurant_admin' || getUserData().role == 'staff') && 
             getUserData().restaurantId == restaurantId;
    }

    function isExistingOwner(ownerIdField) {
      return isSignedIn() && resource != null && resource.data[ownerIdField] == request.auth.uid;
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isPlatformAdmin());
    }

    // --- COLLECTION RULES ---

    match /customerProfiles/{customerId} {
      allow get: if isOwner(customerId) || isSignedIn(); 
      allow list: if isPlatformAdmin();
      allow create: if isSignedIn() && request.resource.data.firebaseAuthUid == request.auth.uid;
      allow update: if isOwner(customerId);
      allow delete: if isPlatformAdmin();

      match /addresses/{addressId} {
        allow read, write: if isOwner(customerId) || isPlatformAdmin();
      }
    }

    match /restaurants/{restaurantId} {
      // Allow public discovery of restaurants and their settings for storefront rendering
      allow get, list: if true;
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin() || isRestaurantAdmin(restaurantId);
      allow delete: if isPlatformAdmin();

      match /orders/{orderId} {
        allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isRestaurantAdmin(restaurantId) || isPlatformAdmin());
        allow create: if isSignedIn();
        allow update: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
        allow delete: if isPlatformAdmin();
      }

      match /menus/{menuId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
        
        match /items/{itemId} {
          allow read: if true;
          allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
        }
      }

      match /gallery/{imageId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
      }

      match /design/{docId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
      }

      match /config/{docId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
      }

      match /features/{docId} {
        allow read: if true;
        allow write: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
      }

      match /reservations/{reservationId} {
        allow get, list: if isRestaurantAdmin(restaurantId) || isPlatformAdmin() || (isSignedIn() && (resource == null || resource.data.customerId == request.auth.uid));
        allow create: if isSignedIn();
        allow update: if isRestaurantAdmin(restaurantId) || isPlatformAdmin() || (isSignedIn() && resource.data.customerId == request.auth.uid);
        allow delete: if isRestaurantAdmin(restaurantId) || isPlatformAdmin();
      }
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isExistingOwner('customerId') || isPlatformAdmin();
    }

    match /users/{userId} {
      // Simplified user rules to avoid potential recursion in helper functions
      allow read: if isSignedIn() && (request.auth.uid == userId || isPlatformAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isPlatformAdmin());
    }
    
    match /cities/{cityId} {
      allow read: if true;
      allow create: if isSignedIn();
    }
    
    match /tiers/{tierId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }
    
    match /partners/{partnerId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin();
    }
    
    match /mail/{mailId} {
      allow create: if isSignedIn();
    }
  }
}