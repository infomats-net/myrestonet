
{
  "entities": {
    "CustomerProfile": {
      "title": "CustomerProfile",
      "type": "object",
      "description": "Stores information specific to a customer account.",
      "properties": {
        "id": { "type": "string" },
        "firebaseAuthUid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "loyaltyPoints": { "type": "number" },
        "walletBalance": { "type": "number" },
        "referralCode": { "type": "string" },
        "favoriteMenuItemIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Restaurant": {
      "title": "Restaurant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "adminEmail": { "type": "string" },
        "cuisine": { "type": "array", "items": { "type": "string" } },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "subscriptionStatus": { "type": "string" },
        "tables": { "type": "array", "items": { "type": "object" } }
      }
    },
    "MenuItem": {
      "title": "MenuItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "specialPrice": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "inventory": { "type": "number" },
        "isPopular": { "type": "boolean" },
        "isNew": { "type": "boolean" },
        "isOutOfStock": { "type": "boolean" },
        "addOns": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "restaurantId": { "type": "string" },
        "customerId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Reservation": {
      "title": "Reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "restaurantId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "partySize": { "type": "number" },
        "status": { "type": "string" },
        "tableIds": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com", "apple.com", "anonymous"]
  },
  "firestore": {
    "structure": {
      "/customerProfiles/{customerId}": {
        "schema": "#/backend/entities/CustomerProfile",
        "description": "Registered customer profiles."
      },
      "/restaurants/{restaurantId}": {
        "schema": "#/backend/entities/Restaurant",
        "description": "Restaurant tenant data."
      },
      "/restaurants/{restaurantId}/menus/{menuId}/items/{itemId}": {
        "schema": "#/backend/entities/MenuItem",
        "description": "Menu items within categories."
      },
      "/restaurants/{restaurantId}/reservations/{reservationId}": {
        "schema": "#/backend/entities/Reservation",
        "description": "Tenant-specific bookings."
      },
      "/orders/{orderId}": {
        "schema": "#/backend/entities/Order",
        "description": "Global orders collection."
      }
    }
  }
}
