
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "restaurant_admin", "staff"] },
        "restaurantId": { "type": "string", "description": "The tenant ID this user belongs to (null for super_admin)." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminUserId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "baseCurrency": { "type": "string" },
        "baseLanguage": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "suspended", "trial"] },
        "paymentSettings": {
          "type": "object",
          "properties": {
            "stripe": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "publishableKey": { "type": "string" },
                "accountId": { "type": "string" }
              }
            },
            "paypal": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "clientId": { "type": "string" }
              }
            },
            "cod": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        },
        "deliverySettings": {
          "type": "object",
          "properties": {
            "deliveryCharge": { "type": "number" },
            "freeDeliveryAbove": { "type": "number" },
            "deliveryEnabled": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminUserId"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "status": { "type": "string" },
        "subtotal": { "type": "number" },
        "deliveryCharge": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["stripe", "paypal", "cod"] },
        "paymentStatus": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "MenuItem": {
      "title": "MenuItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Global users collection for role-based access control."
    },
    "/restaurants/{restaurantId}": {
      "schema": { "$ref": "#/backend/entities/Restaurant" },
      "description": "Tenant root document."
    },
    "/restaurants/{restaurantId}/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Tenant-specific orders subcollection."
    },
    "/restaurants/{restaurantId}/menu/{menuItemId}": {
      "schema": { "$ref": "#/backend/entities/MenuItem" },
      "description": "Tenant-specific menu subcollection."
    }
  }
}
