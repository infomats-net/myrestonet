
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "marketing_partner", "restaurant_admin", "staff", "support", "helper"] },
        "restaurantId": { "type": "string", "description": "The tenant ID this user belongs to (null for admins/partners)." },
        "partnerId": { "type": "string", "description": "The partner ID this user belongs to (null for super_admin)." },
        "assignedRestaurants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "restaurantId": { "type": "string" },
              "permissions": { "type": "array", "items": { "type": "string", "enum": ["read", "update_settings", "guide"] } },
              "expiryDate": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role"]
    },
    "Ticket": {
      "title": "Support Ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "pending", "resolved", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "category": { "type": "string" },
        "restaurantId": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastReplyAt": { "type": "string", "format": "date-time" }
      }
    },
    "TicketMessage": {
      "title": "Ticket Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderUid": { "type": "string" },
        "senderRole": { "type": "string" },
        "message": { "type": "string" },
        "attachmentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Partner": {
      "title": "Partner",
      "description": "A reseller or marketing agency that onboards restaurants.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "country": { "type": "string" },
        "commissionRate": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "commissionRate"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminUserId": { "type": "string" },
        "partnerId": { "type": "string" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "customDomain": { "type": "string" },
        "logoUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "suspended", "trial"] },
        "tierId": { "type": "string" },
        "baseCurrency": { "type": "string", "default": "USD" },
        "stripeAccountId": { "type": "string", "description": "Connected Stripe Connect account ID." },
        "paymentsEnabled": { "type": "boolean", "default": false },
        "tables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "size": { "type": "number" },
              "location": { "type": "string", "enum": ["Indoor", "Outdoor", "Window", "Bar"] },
              "isActive": { "type": "boolean" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SubscriptionTier": {
      "title": "SubscriptionTier",
      "description": "A pricing plan for the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "period": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "popular": { "type": "boolean" },
        "activeTenants": { "type": "number" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string", "description": "Numeric order ID for easy staff reference." },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "currency": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["cod", "stripe", "paypal"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "refunded"] },
        "stripePaymentIntentId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "preparing", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/UserProfile" } },
    "/partners/{partnerId}": { "schema": { "$ref": "#/backend/entities/Partner" } },
    "/restaurants/{restaurantId}": { "schema": { "$ref": "#/backend/entities/Restaurant" } },
    "/restaurants/{restaurantId}/orders/{orderId}": { "schema": { "$ref": "#/backend/entities/Order" } },
    "/restaurants/{restaurantId}/tickets/{ticketId}": { "schema": { "$ref": "#/backend/entities/Ticket" } },
    "/restaurants/{restaurantId}/tickets/{ticketId}/messages/{messageId}": { "schema": { "$ref": "#/backend/entities/TicketMessage" } },
    "/tiers/{tierId}": { "schema": { "$ref": "#/backend/entities/SubscriptionTier" } }
  }
}
