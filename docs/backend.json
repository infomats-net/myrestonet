
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "marketing_partner", "restaurant_admin", "staff", "support", "helper"] },
        "restaurantId": { "type": "string", "description": "The tenant ID this user belongs to (null for admins/partners)." },
        "partnerId": { "type": "string", "description": "The partner ID this user belongs to (null for super_admin)." },
        "assignedRestaurants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "restaurantId": { "type": "string" },
              "permissions": { "type": "array", "items": { "type": "string", "enum": ["read", "update_settings", "guide"] } },
              "expiryDate": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role"]
    },
    "Partner": {
      "title": "Partner",
      "description": "A reseller or marketing agency that onboards restaurants.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "country": { "type": "string" },
        "commissionRate": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "commissionRate"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminUserId": { "type": "string" },
        "partnerId": { "type": "string" },
        "name": { "type": "string" },
        "city": { "type": "string" },
        "country": { "type": "string" },
        "customDomain": { "type": "string" },
        "logoUrl": { "type": "string", "description": "URL to the restaurant logo image." },
        "bannerUrl": { "type": "string", "description": "URL to the restaurant hero banner image." },
        "subscriptionStatus": { "type": "string", "enum": ["active", "suspended", "trial"] },
        "tables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "size": { "type": "number" },
              "location": { "type": "string", "enum": ["Indoor", "Outdoor", "Window", "Bar"] },
              "isActive": { "type": "boolean" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Menu": {
      "title": "Menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "MenuItem": {
      "title": "MenuItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Reservation": {
      "title": "Reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "tableIds": { "type": "array", "items": { "type": "string" } },
        "dateTime": { "type": "string", "format": "date-time" },
        "partySize": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "specialRequests": { "type": "string" },
        "waitlist": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GalleryImage": {
      "title": "GalleryImage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "subtotal": { "type": "number" },
        "deliveryCharges": { "type": "number" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cod", "stripe", "paypal"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "orderStatus": { "type": "string", "enum": ["new", "preparing", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Mail": {
      "title": "Mail",
      "description": "Firestore-triggered email document for transactional notifications.",
      "type": "object",
      "properties": {
        "to": { "type": "array", "items": { "type": "string" } },
        "message": {
          "type": "object",
          "properties": {
            "subject": { "type": "string" },
            "text": { "type": "string" },
            "html": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["to", "message"]
    },
    "Country": {
      "title": "Country",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "State": {
      "title": "State",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "countryId": { "type": "string" }
      }
    },
    "City": {
      "title": "City",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "stateId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "Users." },
    "/partners/{partnerId}": { "schema": { "$ref": "#/backend/entities/Partner" }, "description": "Partners." },
    "/restaurants/{restaurantId}": { "schema": { "$ref": "#/backend/entities/Restaurant" }, "description": "Restaurants." },
    "/restaurants/{restaurantId}/menus/{menuId}": { "schema": { "$ref": "#/backend/entities/Menu" }, "description": "Restaurant Menus." },
    "/restaurants/{restaurantId}/menus/{menuId}/items/{itemId}": { "schema": { "$ref": "#/backend/entities/MenuItem" }, "description": "Menu Items." },
    "/restaurants/{restaurantId}/reservations/{resId}": { "schema": { "$ref": "#/backend/entities/Reservation" }, "description": "Reservations." },
    "/restaurants/{restaurantId}/gallery/{imageId}": { "schema": { "$ref": "#/backend/entities/GalleryImage" }, "description": "Photo Gallery Images." },
    "/restaurants/{restaurantId}/orders/{orderId}": { "schema": { "$ref": "#/backend/entities/Order" }, "description": "Restaurant Orders." },
    "/mail/{mailId}": { "schema": { "$ref": "#/backend/entities/Mail" }, "description": "Outbound Email Queue." },
    "/countries/{countryId}": { "schema": { "$ref": "#/backend/entities/Country" }, "description": "Global Countries." },
    "/states/{stateId}": { "schema": { "$ref": "#/backend/entities/State" }, "description": "Regional States/Provinces." },
    "/cities/{cityId}": { "schema": { "$ref": "#/backend/entities/City" }, "description": "Regional Cities." }
  }
}
