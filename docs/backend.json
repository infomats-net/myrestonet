
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "restaurant_admin", "staff"] },
        "restaurantId": { "type": "string", "description": "The tenant ID this user belongs to." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminUserId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "baseCurrency": { "type": "string" },
        "baseLanguage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminUserId"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "status": { "type": "string" },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "MenuItem": {
      "title": "MenuItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Global users collection."
    },
    "/restaurants/{restaurantId}": {
      "schema": { "$ref": "#/backend/entities/Restaurant" },
      "description": "Tenant root document."
    },
    "/restaurants/{restaurantId}/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Tenant-specific orders."
    },
    "/restaurants/{restaurantId}/menu/{menuItemId}": {
      "schema": { "$ref": "#/backend/entities/MenuItem" },
      "description": "Tenant-specific menu items."
    }
  }
}
