
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "marketing_partner", "restaurant_admin", "staff", "support", "helper"] },
        "restaurantId": { "type": "string", "description": "The tenant ID this user belongs to (null for admins/partners)." },
        "partnerId": { "type": "string", "description": "The partner ID this user belongs to (null for super_admin)." },
        "assignedRestaurants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "restaurantId": { "type": "string" },
              "permissions": { "type": "array", "items": { "type": "string", "enum": ["read", "update_settings", "guide"] } },
              "expiryDate": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role"]
    },
    "Partner": {
      "title": "Partner",
      "description": "A reseller or marketing agency that onboards restaurants.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "country": { "type": "string" },
        "commissionRate": { "type": "number", "description": "Percentage commission earned per order." },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "commissionRate"]
    },
    "Restaurant": {
      "title": "Restaurant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adminUserId": { "type": "string" },
        "partnerId": { "type": "string", "description": "The partner that onboarded this restaurant." },
        "name": { "type": "string" },
        "customDomain": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "suspended", "trial"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminUserId"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Global users collection."
    },
    "/partners/{partnerId}": {
      "schema": { "$ref": "#/backend/entities/Partner" },
      "description": "Marketing partners."
    },
    "/restaurants/{restaurantId}": {
      "schema": { "$ref": "#/backend/entities/Restaurant" },
      "description": "Restaurant tenants."
    }
  }
}
